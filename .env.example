# ─── Server ───────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
ORIGIN=https://your-domain.example.com

# ─── Session ──────────────────────────────────────────
# REQUIRED in production — must be changed from default!
# Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# ─── S3 Defaults (pre-fill login form) ───────────────
# S3_DEFAULT_ENDPOINT=http://localhost:9000
# S3_DEFAULT_REGION=us-east-1

# ─── Fixed Credentials Mode (skip login form) ────────
# WARNING: All users share these credentials. Only use behind VPN/auth proxy.
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=
# S3_REGION=us-east-1
# S3_SESSION_TOKEN=

# ─── OIDC / SSO (Okta, Keycloak, Azure AD, etc.) ────
# OIDC_ISSUER=https://your-idp.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_SCOPES=openid profile email
